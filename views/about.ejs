<script>
const revealElements = document.querySelectorAll(".reveal-left, .reveal-right");

  function revealOnScroll() {
    const windowHeight = window.innerHeight;

    revealElements.forEach((el) => {
      const top = el.getBoundingClientRect().top;
      const visiblePoint = 120;

      if (top < windowHeight - visiblePoint) {
        el.classList.add("active");
      }
    });
  }

  window.addEventListener("scroll", revealOnScroll);
  window.addEventListener("load", revealOnScroll);
  // ABOUT HERO TYPEWRITER
const aboutTypingText = document.getElementById("aboutTypingText");
const aboutHeroText = "Purpose-Driven Educational Travel Platform";
let aboutIndex = 0;

function typeAboutHero() {
  if (!aboutTypingText) return;

  if (aboutIndex < aboutHeroText.length) {
    aboutTypingText.textContent += aboutHeroText.charAt(aboutIndex);
    aboutIndex++;
    setTimeout(typeAboutHero, 55);
  }
}

window.addEventListener("load", typeAboutHero);

// BACKGROUND PARALLAX MOVEMENT
window.addEventListener("scroll", () => {
  const hero = document.querySelector(".about-parallax");
  if (!hero) return;

  const scrollValue = window.scrollY;
  hero.style.backgroundPosition = `center ${scrollValue * 0.25}px`;
});
</script>