<% layout("/layouts/admin") %>

<div class="admin-stats-grid">
  <div class="admin-stat-card">
    <div class="stat-icon blue">
      <i class="fa-solid fa-map-location-dot"></i>
    </div>
    <div>
      <h3><%= totalListings || 0 %></h3>
      <p>Total Tours</p>
    </div>
  </div>

  <div class="admin-stat-card">
    <div class="stat-icon green">
      <i class="fa-solid fa-calendar-check"></i>
    </div>
    <div>
      <h3><%= totalBookings || 0 %></h3>
      <p>Total Bookings</p>
    </div>
  </div>

  <div class="admin-stat-card">
    <div class="stat-icon orange">
      <i class="fa-solid fa-users"></i>
    </div>
    <div>
      <h3><%= totalUsers || 0 %></h3>
      <p>Registered Users</p>
    </div>
  </div>

  <div class="admin-stat-card">
    <div class="stat-icon red">
      <i class="fa-solid fa-hourglass-half"></i>
    </div>
    <div>
      <h3><%= pendingBookings || 0 %></h3>
      <p>Pending Requests</p>
    </div>
  </div>

  <a href="/admin/contacts" class="text-decoration-none text-dark">
    <div class="admin-stat-card">
      <div class="stat-icon purple">
        <i class="fa-solid fa-envelope"></i>
      </div>
      <div>
        <h3><%= totalContacts || 0 %></h3>
        <p>Contact Inquiries</p>
      </div>
    </div>
  </a>
</div>

<div class="admin-grid-2">
  <div class="admin-panel-card">
    <div class="panel-header">
      <h4>Recent Bookings</h4>
      <a href="/admin/bookings">View All</a>
    </div>

    <div class="table-responsive">
      <table class="table admin-table">
        <thead>
          <tr>
            <th>User</th>
            <th>Tour</th>
            <th>Total</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% if (bookings && bookings.length > 0) { %>
            <% bookings.forEach(function(booking) { %>
              <tr>
                <td><%= booking.user && booking.user.username ? booking.user.username : "N/A" %></td>
                <td><%= booking.listing && booking.listing.title ? booking.listing.title : "Deleted Listing" %></td>
                <td>₹ <%= Number(booking.totalPrice || 0).toLocaleString("en-IN") %></td>
                <td>
                  <span class="status-badge <%= booking.status === 'confirmed' ? 'success' : booking.status === 'pending' ? 'pending' : 'cancelled' %>">
                    <%= booking.status === "pending" ? "Pending Approval" : booking.status === "confirmed" ? "Approved" : "Cancelled" %>
                  </span>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="4" class="text-center">No bookings found</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="admin-panel-card">
    <div class="panel-header">
      <h4>Recent Tour Packages</h4>
      <a href="/admin/listings">View All</a>
    </div>

    <div class="row">
      <% if (listings && listings.length > 0) { %>
        <% listings.forEach(function(listing) { %>
          <div class="col-md-6 mb-3">
           <div class="card admin-search-item shadow-sm border-0 rounded-4 h-100">
              <img
                src="<%= listing.image && listing.image.url ? listing.image.url : 'https://via.placeholder.com/400x250' %>"
                class="card-img-top rounded-top-4"
                style="height:160px; object-fit:cover;"
                alt="Tour Image"
              >

              <div class="card-body">
                <h6 class="fw-bold mb-1"><%= listing.title || "Untitled Package" %></h6>

                <p class="mb-1 small text-muted">
                  <%= listing.location || "-" %>, <%= listing.country || "India" %>
                </p>

                <p class="mb-1 small">
                  <strong>Duration:</strong> <%= listing.duration || "-" %>
                </p>

                <p class="mb-2 small">
                  <strong>Price:</strong>
                  ₹ <%= Number(listing.pricePerPerson || listing.price || 0).toLocaleString("en-IN") %>
                </p>

                <a href="/listings/<%= listing._id %>" class="btn btn-outline-dark btn-sm">View</a>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <p class="text-muted">No packages found.</p>
      <% } %>
    </div>
  </div>
</div>
<script>
  const searchInput = document.getElementById("adminSearch");

  searchInput.addEventListener("keyup", function () {
    const value = this.value.toLowerCase();

    const items = document.querySelectorAll(".admin-search-item");

    items.forEach(item => {
      const text = item.innerText.toLowerCase();

      if (text.includes(value)) {
        item.style.display = "block";
      } else {
        item.style.display = "none";
      }
    });
  });
</script>