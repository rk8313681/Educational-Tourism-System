<% layout("/layouts/admin") %>

<div class="admin-panel-card">
  <div class="panel-header">
    <h4>Manage Users</h4>
  </div>

  <div class="table-responsive">
    <table class="table admin-table">
      <thead>
        <tr>
          <th>Username</th>
          <th>Email</th>
          <th>Role</th>
          <th>OTP Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (users.length > 0) { %>
          <% users.forEach(user => { %>
            <tr>
              <td><%= user.username %></td>
              <td><%= user.email %></td>
              <td><%= user.role || "user" %></td>
              <td>
                <% if (user.otp) { %>
                  <span class="status-badge pending">Active OTP</span>
                <% } else { %>
                  <span class="status-badge success">Normal</span>
                <% } %>
              </td>
             <td>
  <% if (currUser && currUser.role === "admin" && String(currUser._id) === String(user._id)) { %>
    <span style="color:#6b7280; font-weight:700;">Current Admin</span>
  <% } else { %>
    <form action="/admin/users/<%= user._id %>?_method=DELETE" method="POST" style="display:inline;">
      <button type="submit" class="table-action delete" style="border:none; background:none;">Delete</button>
    </form>
  <% } %>
</td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="5" class="text-center">No users found</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>