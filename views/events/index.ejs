<% layout("/layouts/boilerplate") %>

<section class="edu-events-hero">
  <div class="edu-events-overlay"></div>
  <div class="edu-events-hero-content reveal reveal-up">
    <span class="event-mini-badge">Educational Events</span>
    <h1>Educational Events & Opportunities</h1>
    <p>Explore learning events, competitions, science exhibitions and government programs for students.</p>

    <div class="event-filter-pills">
      <a href="/events?type=g20">🌍 G20 / Government</a>
      <a href="/events?type=science">🧪 Science Exhibitions</a>
      <a href="/events?type=tech">🤖 Tech Fests</a>
      <a href="/events?type=hackathon">💻 Hackathons</a>
    </div>
  </div>
</section>

<section class="events-section">
  <div class="container">

    <div class="section-heading text-center reveal reveal-up">
      <span class="section-mini-title">Upcoming Events</span>
      <h2>Choose Educational Opportunities</h2>
      <p>Students can participate in curated events for exposure, skills, innovation and career growth.</p>
    </div>

    <div class="row g-4 mt-3">

      <div class="col-md-6 col-lg-3 reveal reveal-up">
        <div class="edu-event-card">
          <div class="event-icon">🌍</div>
          <span class="event-type">G20 / Government</span>
          <h4>G20 Youth Summit</h4>
          <p><i class="fa-solid fa-calendar-days"></i> 12 Oct 2026</p>
          <p><i class="fa-solid fa-location-dot"></i> Delhi</p>
          <p class="event-desc">Participate in youth policy discussion, leadership sessions and government exposure.</p>
          <a href="/contact?subject=G20 Youth Summit" class="event-apply-btn">Apply Now</a>
        </div>
      </div>

      <div class="col-md-6 col-lg-3 reveal reveal-up">
        <div class="edu-event-card">
          <div class="event-icon">🧪</div>
          <span class="event-type">Science Exhibition</span>
          <h4>National Science Exhibition</h4>
          <p><i class="fa-solid fa-calendar-days"></i> 20 Aug 2026</p>
          <p><i class="fa-solid fa-location-dot"></i> Delhi</p>
          <p class="event-desc">Explore science models, innovation projects, research displays and student competitions.</p>
          <a href="/contact?subject=National Science Exhibition" class="event-apply-btn">Apply Now</a>
        </div>
      </div>

      <div class="col-md-6 col-lg-3 reveal reveal-up">
        <div class="edu-event-card">
          <div class="event-icon">🤖</div>
          <span class="event-type">Tech Fest & Robotics</span>
          <h4>Robotics Innovation Fest</h4>
          <p><i class="fa-solid fa-calendar-days"></i> 05 Sep 2026</p>
          <p><i class="fa-solid fa-location-dot"></i> Bangalore</p>
          <p class="event-desc">Attend robotics demos, AI workshops, coding contests and innovation showcases.</p>
          <a href="/contact?subject=Robotics Innovation Fest" class="event-apply-btn">Apply Now</a>
        </div>
      </div>

      <div class="col-md-6 col-lg-3 reveal reveal-up">
        <div class="edu-event-card">
          <div class="event-icon">💻</div>
          <span class="event-type">Hackathon</span>
          <h4>AI Hackathon</h4>
          <p><i class="fa-solid fa-calendar-days"></i> 15 Sep 2026</p>
          <p><i class="fa-solid fa-location-dot"></i> Hyderabad</p>
          <p class="event-desc">Build real solutions, compete with teams and improve technical problem-solving skills.</p>
          <a href="/contact?subject=AI Hackathon" class="event-apply-btn">Apply Now</a>
        </div>
      </div>

    </div>
  </div>
</section>

<section class="events-why-section">
  <div class="container">
    <div class="row align-items-center g-4">
      <div class="col-lg-6 reveal reveal-left">
        <div class="events-info-card">
          <span class="section-mini-title">Why Events?</span>
          <h2>Real Exposure Beyond Classroom</h2>
          <p>Educational events help students learn communication, innovation, leadership and teamwork through practical participation.</p>

          <div class="event-benefit"><i class="fa-solid fa-circle-check"></i> Skill-based learning exposure</div>
          <div class="event-benefit"><i class="fa-solid fa-circle-check"></i> Government, science and tech awareness</div>
          <div class="event-benefit"><i class="fa-solid fa-circle-check"></i> Useful for schools and colleges</div>
        </div>
      </div>

      <div class="col-lg-6 reveal reveal-right">
        <div class="events-image-box">
          <img src="https://images.unsplash.com/photo-1523580846011-d3a5bc25702b?q=80&w=1200&auto=format&fit=crop" alt="Educational Events">
        </div>
      </div>
    </div>
  </div>
</section>