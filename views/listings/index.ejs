<script>
  const searchInput = document.querySelector(".hero-search-bar input");
  const suggestionsBox = document.getElementById("suggestions-box");
  const micIcon = document.querySelector(".mic-icon");

  let activeIndex = -1;
  let suggestions = [];

  function getIcon(category = "", title = "") {
    const text = (category + " " + title).toLowerCase();

    if (text.includes("government") || text.includes("parliament") || text.includes("court")) return "🏛";
    if (text.includes("science") || text.includes("isro") || text.includes("drdo")) return "🧪";
    if (text.includes("career") || text.includes("campus") || text.includes("iit")) return "🎓";
    if (text.includes("industry") || text.includes("infosys")) return "🏢";
    if (text.includes("medical") || text.includes("aiims")) return "🏥";

    return "📍";
  }

  function renderSuggestions(data) {
    suggestionsBox.innerHTML = "";
    activeIndex = -1;
    suggestions = data;

    if (!data.length) {
      suggestionsBox.innerHTML = `<div class="suggestion-item no-result">No results found</div>`;
      suggestionsBox.style.display = "block";
      return;
    }

    data.forEach((item, index) => {
      const div = document.createElement("div");
      div.className = "suggestion-item";
      div.innerHTML = `
        <span class="suggestion-icon">${getIcon(item.category, item.title)}</span>
        <span>
          <strong>${item.title}</strong><br>
          <small>${item.location} • ${item.category}</small>
        </span>
      `;

      div.onclick = function () {
        window.location.href = `/listings?search=${encodeURIComponent(item.title)}`;
      };

      suggestionsBox.appendChild(div);
    });

    suggestionsBox.style.display = "block";
  }

  if (searchInput && suggestionsBox) {
    searchInput.addEventListener("input", async function () {
      const query = searchInput.value.trim();

      if (query.length < 1) {
        suggestionsBox.style.display = "none";
        suggestionsBox.innerHTML = "";
        return;
      }

      const res = await fetch(`/listings/search-suggestions?q=${encodeURIComponent(query)}`);
      const data = await res.json();

      renderSuggestions(data);
    });

    searchInput.addEventListener("keydown", function (e) {
      const items = suggestionsBox.querySelectorAll(".suggestion-item:not(.no-result)");

      if (e.key === "ArrowDown") {
        e.preventDefault();
        activeIndex = (activeIndex + 1) % items.length;
      }

      if (e.key === "ArrowUp") {
        e.preventDefault();
        activeIndex = (activeIndex - 1 + items.length) % items.length;
      }

      if (e.key === "Enter") {
        if (activeIndex >= 0 && suggestions[activeIndex]) {
          e.preventDefault();
          window.location.href = `/listings?search=${encodeURIComponent(suggestions[activeIndex].title)}`;
        }
      }

      items.forEach((item, index) => {
        item.classList.toggle("active", index === activeIndex);
      });
    });

    document.addEventListener("click", function (e) {
      if (!e.target.closest(".hero-search-bar") && !e.target.closest("#suggestions-box")) {
        suggestionsBox.style.display = "none";
      }
    });
  }
  // 🎤 VOICE SEARCH
if (micIcon && searchInput) {
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

  if (SpeechRecognition) {
    const recognition = new SpeechRecognition();

    recognition.lang = "en-IN";
    recognition.continuous = false;
    recognition.interimResults = false;

    micIcon.style.cursor = "pointer";

    micIcon.addEventListener("click", function () {
      recognition.start();
      micIcon.style.color = "#d4a017"; // active color
    });

    recognition.onresult = function (event) {
      const voiceText = event.results[0][0].transcript;

      searchInput.value = voiceText;

      // auto search
      window.location.href = `/listings?search=${encodeURIComponent(voiceText)}`;
    };

    recognition.onend = function () {
      micIcon.style.color = "#8f8f8f";
    };

    recognition.onerror = function () {
      alert("Microphone permission allow karo");
      micIcon.style.color = "#8f8f8f";
    };

  } else {
    micIcon.addEventListener("click", function () {
      alert("Voice search only Chrome me work karta hai");
    });
  }
}
// HOME CARD STAGGER ANIMATION
const animateItems = document.querySelectorAll(".fade-left, .fade-right, .fade-up");
animateItems.forEach((item) => {
  item.style.transitionDelay = item.dataset.delay + "s";
});

function runHomeAnimations() {
  animateItems.forEach((item) => {
    const top = item.getBoundingClientRect().top;

    if (top < window.innerHeight - 80) {
      item.classList.add("show");
    }
  });
}

window.addEventListener("scroll", runHomeAnimations);
window.addEventListener("load", runHomeAnimations);

// HERO TYPING TEXT
const typingText = document.getElementById("typingText");
const heroText = "Explore Educational Tours for Students";
let typingIndex = 0;

function typeHeroText() {
  if (!typingText) return;

  if (typingIndex < heroText.length) {
    typingText.textContent += heroText.charAt(typingIndex);
    typingIndex++;
    setTimeout(typeHeroText, 55);
  }
}

window.addEventListener("load", typeHeroText);
</script>
