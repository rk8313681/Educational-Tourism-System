<% layout("/layouts/boilerplate") %>

<section class="hero">
  <div class="hero-overlay"></div>

  <div class="hero-inner">
    <div class="hero-content text-center text-white">
     <h1 class="hero-title hero-animate delay-1">
  <span id="typingText"></span>
</h1>
     <p class="hero-subtitle hero-animate delay-2">Campus Visits • Industry Exposure • Parliament Tours • Science & Innovation Trips</p>

<form action="/listings" method="GET" class="hero-search-bar">
  <i class="fa-solid fa-magnifying-glass search-icon"></i>

<input
  type="text"
  name="search"
  placeholder="Search Parliament, DRDO, ISRO, AIIMS, Delhi..."
  value="<%= typeof search !== 'undefined' ? search : '' %>"
>

  <button type="submit" class="hero-search-btn">
    <i class="fa-solid fa-magnifying-glass"></i>
  </button>

  <i class="fa-solid fa-microphone mic-icon"></i>
</form>

<div id="suggestions-box" class="suggestions-box"></div>
      <div class="hero-stats hero-animate delay-4">
        <div class="hero-stat-box">
          <h3><%= listings && listings.length ? listings.length : 0 %>+</h3>
          <p>Educational Tours</p>
        </div>

<div class="hero-stat-box">
  <h3>12+</h3>
  <p>Educational Visits</p>
</div>

        <div class="hero-stat-box">
          <h3>College</h3>
          <p>Friendly Packages</p>
        </div>
      </div>
    </div>
  </div>
</section>


<div class="container mt-5" id="packages">
<h2 class="text-center mb-4">
  <% if (typeof search !== "undefined" && search) { %>
    Search Results for "<%= search %>"
  <% } else { %>
    Educational Tour Packages for Schools & Colleges
  <% } %>
</h2>


  <div class="row mt-4">
    <% if (listings && listings.length > 0) { %>
      <% listings.forEach(function(listing, i) { %>
      <div class="col-lg-4 col-md-6 col-sm-12 mb-4 d-flex <%= i % 3 === 0 ? 'fade-left' : (i % 3 === 1 ? 'fade-up' : 'fade-right') %>" data-delay="<%= (i % 6) * 0.12 %>">
         <div class="card tour-card border-0 shadow-sm h-100 w-100 rounded-4 overflow-hidden"
     onclick="window.location.href='/listings/<%= listing._id %>'"
     style="cursor:pointer;">
           <span class="badge bg-warning text-dark position-absolute m-2">
  <%= listing.category %>
</span>
            <div class="card-img-container position-relative">
              <img
                src="<%= listing.image && listing.image.url ? listing.image.url : 'https://images.unsplash.com/photo-1503676260728-1c00da094a0b?q=80&w=800&auto=format&fit=crop' %>"
                class="card-img-top"
                style="height: 230px; object-fit: cover;"
                onerror="this.src='https://images.unsplash.com/photo-1503676260728-1c00da094a0b?q=80&w=800&auto=format&fit=crop';"
                alt="<%= listing.title %>"
              >
<div class="card-title-overlay">

  <h5><%= listing.title || "Educational Tour" %></h5>

  <div class="overlay-bottom">
    <!-- LEFT: PRICE -->
    <div class="overlay-price">
      ₹ <%= Number(listing.pricePerPerson || listing.price || 0).toLocaleString("en-IN") %>
      <span>per person</span>
    </div>

    <!-- RIGHT: LOCATION -->
    <div class="overlay-location">
      📍 <%= listing.location || "-" %>
    </div>
  </div>

</div>
</div>

<div class="card-body d-flex flex-column">
</div>

          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="col-12">
        <div class="alert alert-light border rounded-4 shadow-sm text-center">
          No tour packages available right now.
        </div>
      </div>
    <% } %>
  </div>
</div>

