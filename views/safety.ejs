<% layout("/layouts/boilerplate") %>

<section class="edu-safety-section py-5">

  <div class="container">

    <div class="row align-items-center g-5">

      <!-- LEFT -->
      <div class="col-lg-6">

        <span class="safety-tag">
          Student Safety & Verification
        </span>

        <h2 class="safety-heading">
          Safe, Verified & Institution-Focused Educational Tours
        </h2>

        <p class="safety-text">
          Our platform focuses on verified educational participation,
          faculty-supervised travel and secure student batch management
          for colleges and universities.
        </p>

        <div class="safety-features">

          <div class="safety-item">
            ✅ Student ID Verification
          </div>

          <div class="safety-item">
            ✅ Faculty Supervised Educational Visits
          </div>

          <div class="safety-item">
            ✅ Secure Batch Management
          </div>

          <div class="safety-item">
            ✅ Institution Based Participation
          </div>

        </div>

      </div>

      <!-- RIGHT -->
      <div class="col-lg-6">

        <div class="safety-image-box">

          <img
            src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=1400&auto=format&fit=crop"
            alt="Educational Tour Safety"
            class="img-fluid rounded-4"
          >

          <div class="safety-floating-card">

            <h4>Educational Travel Safety</h4>

            <p>
              Institution-based student participation with secure batch
              verification and supervised educational exposure visits.
            </p>

          </div>

        </div>

      </div>

    </div>

  </div>

</section>