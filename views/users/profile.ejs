<% layout("/layouts/boilerplate") %>

<div class="container my-5">
  <div class="profile-card mx-auto">

 <div class="profile-header text-center">
  <div class="profile-avatar">
    <i class="fa-solid fa-user"></i>
  </div>

  <h2 class="mt-3"><%= currUser.username %></h2>
  <p class="text-muted"><%= currUser.email || "Email not available" %></p>
</div>

    <div class="profile-info">
      <div>
        <span>Username</span>
        <strong><%= currUser.username %></strong>
      </div>

      <div>
        <span>Email</span>
        <strong><%= currUser.email || "Not added" %></strong>
      </div>

      <div>
        <span>Role</span>
        <strong><%= currUser.role || "user" %></strong>
      </div>
    </div>

    <div class="profile-actions">
      <a href="/bookings/my" class="btn btn-outline-primary">My Bookings</a>
      <a href="/logout" class="btn btn-outline-danger">Logout</a>
    </div>

  </div>
</div>